# ── Daily Briefing Agent — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in each value.
# Never commit .env to source control.

# --- Model backend (pick one) ------------------------------------------------
# Set BACKEND=ollama to use a local Ollama model, or BACKEND=gemini (default)
# for Google AI Studio.

# Option A: Local Ollama — BACKEND=ollama
# Recommended model: qwen2.5:7b (~4.5 GB, fits in 8 GB VRAM, fast tool calling)
# Do NOT use qwen3:8b — its thinking/reasoning mode produces extremely verbose output.
# OLLAMA_API_BASE=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# BACKEND=ollama

# Option B: Google AI Studio (free tier) — BACKEND=gemini
# https://aistudio.google.com/app/apikey
# Recommended model: gemini-2.5-flash-lite (1,000 RPD) or gemini-3.1-flash-lite (500 RPD)
# Do NOT use gemma-4-* models — they do not support ADK tool/function calling.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite
# BACKEND=gemini


# GNews — https://gnews.io  (free tier: 100 req/day, localhost only)
GNEWS_API_KEY=

# Discord bot — handles both scheduled briefings and conversational messages.
# See docs/analysis/api-setup-guide.md for setup steps.
# 1. Create a bot at https://discord.com/developers/applications
# 2. Enable "Message Content Intent" under Bot → Privileged Gateway Intents
# 3. Copy the bot token below
# 4. Invite the bot with scopes: bot  Permissions: Send Messages, Read Message History
DISCORD_BOT_TOKEN=

# Channel the bot listens in (right-click channel → Copy Channel ID; requires Developer Mode)
DISCORD_BOT_CHANNEL_ID=

# Google Calendar (private — service account)
# See docs/analysis/google-calendar-private-setup.md for full setup steps.
GOOGLE_CALENDAR_ID=<email_address>
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Supabase vector DB — https://supabase.com/dashboard → Settings → API
# Optional but recommended: enables long-term semantic memory across sessions.
# See docs/integrations/supabase-vector-adk.md for schema setup.
# Without these, the bot starts normally but memory is disabled (a warning is logged).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
