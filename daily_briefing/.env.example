# Option A: Local Ollama — BACKEND=ollama
# OLLAMA_API_BASE=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# BACKEND=ollama

# Option B: Google AI Studio (free tier) — BACKEND=gemini
# GEMINI_MODEL=gemini-2.5-flash-lite
# BACKEND=gemini

# Option C: GitHub Models — BACKEND=github#
GITHUB_API_KEY=
GITHUB_MODEL=gpt-4.1
BACKEND=github

# Gemini (Still needed for embeddings model, even if not using Gemini for the main LLM)
GEMINI_API_KEY=

# GNews — https://gnews.io  (free tier: 100 req/day, localhost only)
GNEWS_API_KEY=

# Tavily web search — https://tavily.com  (free tier: ~1,000 searches/mo)
# Required only on non-Gemini backends (ollama/github); on Gemini, native
# google_search handles ad-hoc web search and this is ignored.
TAVILY_API_KEY=

# Discord bot — handles both scheduled briefings and conversational messages.
DISCORD_BOT_TOKEN=
DISCORD_BOT_CHANNEL_ID=

# Google Calendar (private — service account)
GOOGLE_CALENDAR_ID=<email_address>
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Supabase vector DB — https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Log level (DEBUG | INFO | WARNING | ERROR). Default INFO.
# Agent callbacks (daily_briefing/logging_callbacks.py) emit one compact line
# per prompt, response, and tool call at INFO; DEBUG adds stdlib chatter.
LOG_LEVEL=INFO
