OLLAMA_API_BASE=http://127.0.0.1:11434
OLLAMA_MODEL=smollm2:135m
# For better general chat behavior on this machine, try qwen2.5:0.5b instead.

# ── Daily Briefing Agent ───────────────────────────────────────────────────────

# Google AI (Gemini) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional — override the model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# NewsAPI — https://newsapi.org/register
NEWS_API_KEY=

# Discord webhook — Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# Google Calendar (private — service account)
# See docs/analysis/google-calendar-private-setup.md for full setup steps.
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
